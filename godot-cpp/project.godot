; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are too many and tweaking
; them manually can cause bugs.

config_version=5

[application]

config/name="Minetest"
config/description="Minecraft-like game built with Godot Engine"
config/version="1.0.0"
run/main_scene="res://scenes/menu/MainMenu.tscn"
config/features=PackedStringArray("4.0", "vulkan")
config/icon="res://assets/icon.svg"

[debug]

gdscript/warnings/unused_variable=1
gdscript/warnings/unused_argument=1

[rendering]

vulkan/rendering/enable_high_end_graphics=true
textures/default_filters/use_nearest_mipmap_filter=true
global_illumination/sdfgi/enabled=true
